# ============ Providers ============
PRIMARY_PROVIDER=mock
# FALLBACK_PROVIDER=openai            # used from Phase 4 (failover)
GATEWAY_API_KEYS=gw_sk_demo123
# OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
PROVIDER_TIMEOUT_SECONDS=30
MAX_RETRIES=2

# ============ Cache (Phase 2: exact) ============
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
CACHE_MAX_TEMPERATURE=1.0

# ============ Semantic cache (Phase 3) ============
SEMANTIC_CACHE_ENABLED=true
SIMILARITY_THRESHOLD=0.92
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ============ Infra ============
# Local (no Docker): localhost. In docker-compose these are overridden to service names.
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://gw:gw@localhost:5432/gateway

# ============ Phase 4+ (placeholders) ============
# ANTHROPIC_API_KEY=sk-ant-...
# RATE_LIMIT_CAPACITY=60
# RATE_LIMIT_REFILL_PER_SEC=1
