# ============ Providers ============
PRIMARY_PROVIDER=mock
# FALLBACK_PROVIDER=anthropic         # set a fallback to enable failover
GATEWAY_API_KEYS=gw_sk_demo123
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
OPENAI_BASE_URL=https://api.openai.com/v1
PROVIDER_TIMEOUT_SECONDS=30
MAX_RETRIES=2
RETRY_BACKOFF_BASE_SECONDS=0.1
RETRY_BACKOFF_MAX_SECONDS=2.0

# ============ Cache (Phase 2: exact) ============
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
CACHE_MAX_TEMPERATURE=1.0

# ============ Semantic cache (Phase 3) ============
SEMANTIC_CACHE_ENABLED=true
SIMILARITY_THRESHOLD=0.92
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ============ Rate limiting (Phase 4) ============
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=60               # max burst (bucket size)
RATE_LIMIT_REFILL_PER_SEC=1.0        # sustained requests/sec per key

# ============ Infra ============
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://gw:gw@localhost:5432/gateway
