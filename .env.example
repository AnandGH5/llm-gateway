# ============ Phase 1 ============
# Which provider to use. "mock" needs NO API key — ideal for the first run.
PRIMARY_PROVIDER=mock
# FALLBACK_PROVIDER=openai            # used from Phase 4 (failover)

# Gateway keys clients must send as:  Authorization: Bearer <key>
# Comma-separated to allow several. CHANGE THIS before any public deploy.
GATEWAY_API_KEYS=gw_sk_demo123

# Real provider creds (only needed when PRIMARY_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
PROVIDER_TIMEOUT_SECONDS=30
MAX_RETRIES=2

# ============ Phase 2+ (placeholders, not used yet) ============
# ANTHROPIC_API_KEY=sk-ant-...
# SIMILARITY_THRESHOLD=0.92
# CACHE_TTL_SECONDS=86400
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_DIM=384
# RATE_LIMIT_CAPACITY=60
# RATE_LIMIT_REFILL_PER_SEC=1
# REDIS_URL=redis://localhost:6379/0
# DATABASE_URL=postgresql://gw:gw@localhost:5432/gateway
