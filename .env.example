# ============ Providers ============
# "mock" needs NO API key — ideal for first run and tests.
PRIMARY_PROVIDER=mock
# FALLBACK_PROVIDER=openai            # used from Phase 4 (failover)

# Gateway keys clients send as:  Authorization: Bearer <key>
# Comma-separated to allow several. CHANGE before any public deploy.
GATEWAY_API_KEYS=gw_sk_demo123

# Real provider creds (only when PRIMARY_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
PROVIDER_TIMEOUT_SECONDS=30
MAX_RETRIES=2

# ============ Cache (Phase 2) ============
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
CACHE_MAX_TEMPERATURE=1.0

# ============ Infra ============
# Local (no Docker): localhost. In docker-compose this is overridden to redis:6379.
REDIS_URL=redis://localhost:6379/0

# ============ Phase 3+ (placeholders) ============
# ANTHROPIC_API_KEY=sk-ant-...
# SIMILARITY_THRESHOLD=0.92
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_DIM=384
# DATABASE_URL=postgresql://gw:gw@localhost:5432/gateway
